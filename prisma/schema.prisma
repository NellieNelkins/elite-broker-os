generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Authentication (NextAuth) =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  apiKey        String?   // Encrypted Anthropic API key
  accounts      Account[]
  sessions      Session[]
  contacts      Contact[]
  deals         Deal[]
  listings      Listing[]
  campaigns     Campaign[]
  activities    Activity[]
  viewings      Viewing[]
  documents     Document[]
  coachSessions CoachSession[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== CRM Data Models =====

model Contact {
  id               String       @id @default(cuid())
  userId           String
  name             String
  phone            String
  phone2           String?
  phone3           String?
  email            String?
  type             String       @default("Buyer") // Buyer, Seller, Investor, Tenant, Landlord
  stage            String       @default("Lead")  // Lead, Qualified, Viewing Done, Offer Made, Under Offer, Closed, Lost
  priority         String       @default("MEDIUM") // HIGH, MEDIUM, LOW
  value            Float        @default(0)
  community        String?
  property         String?
  bedrooms         String?
  propType         String?      // Villa, Apartment, Townhouse, Penthouse, Plot
  permitNum        String?
  dldNum           String?
  nationality      String?
  motivation       String?
  source           String?      // WhatsApp, DLD Import, Excel, Bayut, etc.
  notes            String?
  whatsappConnected Boolean     @default(false)
  replied          Boolean      @default(false)
  lastContactedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals            Deal[]
  activities       Activity[]
  campaignContacts CampaignContact[]

  @@index([userId, stage])
  @@index([userId, type])
  @@index([userId, priority])
  @@index([phone])
}

model Deal {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  listingId   String?
  name        String
  stage       String   @default("Lead")
  value       Float    @default(0)
  commission  Float    @default(0)
  probability Float    @default(0)
  community   String?
  property    String?
  nextAction  String?
  nextDate    DateTime?
  notes       String?

  // Transaction milestones (Dubai deal flow)
  offerAcceptedAt    DateTime?
  mouSignedAt        DateTime?
  depositPaidAt      DateTime?
  nocReceivedAt      DateTime?
  trusteeBookedAt    DateTime?
  trusteeDate        DateTime?
  transferredAt      DateTime?
  keysHandedAt       DateTime?

  // Commission split tracking (JSON array of {name, role, pct, amount})
  commissionSplits   Json?
  netCommission      Float   @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  activities  Activity[]
  viewings    Viewing[]
  documents   Document[]

  @@index([userId, stage])
}

model Viewing {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  listingId   String?
  dealId      String?
  scheduledAt DateTime
  duration    Int      @default(30) // minutes
  status      String   @default("scheduled") // scheduled, completed, cancelled, no_show
  location    String?
  notes       String?
  feedback    String?  // Post-viewing feedback
  rating      Int?     // 1-5 interest level from buyer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledAt])
  @@index([userId, status])
}

model Document {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  dealId      String?
  listingId   String?
  name        String
  type        String   // passport, emirates_id, title_deed, ejari, mou, form_a, form_f, noc, other
  url         String
  size        Int      @default(0) // bytes
  mimeType    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([dealId])
}

model Listing {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String   @default("Villa")
  price       Float    @default(0)
  address     String?
  community   String?
  bedrooms    String?
  views       Int      @default(0)
  status      String   @default("Active") // Active, Under Offer, Sold, Draft
  listedAt    DateTime @default(now())
  // Listing checklist steps
  stepDocs    Boolean  @default(false)
  stepPhotos  Boolean  @default(false)
  stepPrice   Boolean  @default(false)
  stepPortal  Boolean  @default(false)
  stepLive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Campaign {
  id          String            @id @default(cuid())
  userId      String
  name        String
  type        String            @default("whatsapp") // whatsapp, email, newsletter, blast
  status      String            @default("draft")    // draft, in_progress, completed, paused
  template    String?
  sentCount   Int               @default(0)
  replyCount  Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts    CampaignContact[]

  @@index([userId, status])
}

model CampaignContact {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  sent       Boolean  @default(false)
  replied    Boolean  @default(false)
  sentAt     DateTime?

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  dealId      String?
  type        String   // call, viewing, offer, message, note, deal_update
  description String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// ===== Market Intelligence =====

model Community {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  emirate         String   @default("Dubai")
  propertyTypes   String   // CSV: Villa, Townhouse, Apartment
  tier            String   @default("standard") // priority, premium, standard
  developer       String?
  handover        String?
  avgPricePerSqft Float    @default(0)
  avgYield        Float    @default(0) // percent
  minPrice        Float    @default(0)
  maxPrice        Float    @default(0)
  amenities       String?  // CSV
  description     String?
  lastRefreshedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dataPoints      MarketDataPoint[]

  @@index([tier])
}

model MarketDataPoint {
  id           String   @id @default(cuid())
  communityId  String
  source       String   // propertymonitor, dxbinteract, propertyfinder, bayut, dld, manual
  bedrooms     String?  // "2", "3", "4", "5", "6+"
  propertyType String   @default("Villa")
  pricePerSqft Float    @default(0)
  avgPrice     Float    @default(0)
  rentalYield  Float    @default(0)
  transactions Int      @default(0)
  capturedAt   DateTime @default(now())

  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, capturedAt])
  @@index([source, capturedAt])
}

model CoachSession {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @default(now())
  habits         Json     @default("[]")
  challengesDone Json     @default("[]")
  streak         Int      @default(0)
  score          Int      @default(0)
  targetCalls    Int      @default(0)
  targetViewings Int      @default(0)
  targetOffers   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
