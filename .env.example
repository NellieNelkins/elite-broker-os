# ===== Elite Broker OS Environment Variables =====
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ---- Database (Supabase PostgreSQL) ----
# Use the "Session Mode" connection string from Supabase Dashboard → Settings → Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ---- NextAuth.js ----
# Set NEXTAUTH_URL to your deployed URL in production
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ---- Google OAuth (for authentication) ----
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Anthropic Claude API ----
# Server-side API key (replaces localStorage storage)
ANTHROPIC_API_KEY=""

# ---- WhatsApp Business API (Optional) ----
# Only needed for automated sending via Meta Cloud API.
# Without these, the app uses direct wa.me links (your personal WhatsApp).
# Setup guide: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="elite-broker-webhook"

# ---- Migration ----
MIGRATION_USER_EMAIL="broker@elitebroker.ae"
