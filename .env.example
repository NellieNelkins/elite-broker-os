# ===== Elite Broker OS Environment Variables =====
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/elite_broker_os"

# ---- NextAuth.js ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ---- Google OAuth (for authentication) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Anthropic Claude API ----
# Server-side API key (replaces localStorage storage)
ANTHROPIC_API_KEY=""

# ---- Migration (scripts/migrate.ts) ----
# Email for the broker user account created during migration
MIGRATION_USER_EMAIL="broker@elitebroker.ae"

# Optional: Google Sheets migration source
# GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
